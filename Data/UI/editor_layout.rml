<rml>
<head>
    <title>Nexus Editor</title>
    <link type="text/rcss" href="editor_style.rcss" />
</head>
<body>
    <div class="editor-root">
        <!-- 左侧 Dock 区域 -->
        <div id="dock-left" class="dock-zone left">
            <div id="panel-hierarchy" class="panel">
                <div class="title-bar" drag="drag">
                    <span class="title-text">场景层级</span>
                </div>
                <div class="panel-content">
                    <div id="hierarchy-tree">
                        <!-- C++ 会在这里动态插入 .tree-node -->
                    </div>
                </div>
            </div>
        </div>

        <!-- 中心视口 -->
        <div id="viewport" class="viewport-area">
        </div>

        <!-- 右侧 Dock 区域 -->
        <div id="dock-right" class="dock-zone right">
            <div id="panel-properties" class="panel">
                <div class="title-bar" drag="drag">
                    <span class="title-text">属性面板</span>
                </div>
                <div class="panel-content" id="properties-content">
                    <h3 style="margin-bottom: 5dp; color:#ffffaa;">Transform</h3>
                    <div class="prop-row">
                        <span class="prop-label">Position X</span>
                        <input id="prop-pos-x" type="text" class="prop-value" value="0.0"/>
                    </div>
                    <div class="prop-row">
                        <span class="prop-label">Position Y</span>
                        <input id="prop-pos-y" type="text" class="prop-value" value="0.0"/>
                    </div>
                    <div class="prop-row">
                        <span class="prop-label">Position Z</span>
                        <input id="prop-pos-z" type="text" class="prop-value" value="0.0"/>
                    </div>
                    <!-- 将来可以继续添加 Rotation, Scale -->
                </div>
            </div>
        </div>
    </div>
</body>
</rml>
